# =============================================
# AERO — Variables de Entorno
# Copia este archivo a .env.local y completa los valores
# NUNCA commitear .env.local
# =============================================

# Supabase (obligatorio)
NEXT_PUBLIC_SUPABASE_URL=https://vtngzjobuhqjnckuyrsx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # Solo servidor, NUNCA exponer al cliente

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Kushki (pagos)
KUSHKI_PUBLIC_KEY=
KUSHKI_PRIVATE_KEY=

# Nequi
NEQUI_API_KEY=
NEQUI_API_URL=https://api.sandbox.connect.nequi.com

# Daviplata
DAVIPLATA_API_KEY=
DAVIPLATA_API_URL=

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aero.app

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
